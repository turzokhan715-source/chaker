// Platform email mappings
const PLATFORM_SENDERS = {
    facebook: ['security@facebookmail.com', 'notification@facebookmail.com', 'no-reply@facebookmail.com'],
    instagram: ['security@mail.instagram.com', 'no-reply@mail.instagram.com']
};

// Extract OTP from email text
function extractOTP(text) {
    // Remove HTML tags
    const cleanText = text.replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ');
    
    const patterns = [
        /\b(\d{6})\b/g,                          // 6-digit code
        /\b(\d{8})\b/g,                          // 8-digit code
        /code[:\s]+(\d{6,8})/gi,                 // "code: 123456"
        /verification code[:\s]+(\d{6,8})/gi,    // "verification code: 123456"
        /(\d{6,8})\s+is your/gi,                 // "123456 is your code"
        /your code is[:\s]+(\d{6,8})/gi,         // "your code is: 123456"
        /login code[:\s]+(\d{6,8})/gi,           // "login code: 123456"
        /confirmation code[:\s]+(\d{6,8})/gi     // "confirmation code: 123456"
    ];

    const foundCodes = new Set();
    
    for (const pattern of patterns) {
        let match;
        while ((match = pattern.exec(cleanText)) !== null) {
            const code = match[1];
            if (code.length >= 6 && code.length <= 8) {
                foundCodes.add(code);
            }
        }
    }

    // Return the first valid code found
    return foundCodes.size > 0 ? Array.from(foundCodes)[0] : null;
}

// Fetch emails via IMAP
async function fetchEmailsViaIMAP(email, password, platform) {
    const client = new ImapFlow({
        host: 'outlook.office365.com',
        port: 993,
        secure: true,
        auth: {
            user: email,
            pass: password
        },
        logger: false
    });

    try {
        await client.connect();
        
        let lock = await client.getMailboxLock('INBOX');
        
        try {
            const platformSenders = PLATFORM_SENDERS[platform] || PLATFORM_SENDERS.facebook;
            
            // Search for emails from platform senders (last 10 emails)
            const messages = [];
            
            for (const sender of platformSenders) {
                try {
                    const searchResults = await client.search({
                        from: sender
                    }, { uid: true });
                    
                    // Get last 5 emails from this sender
                    const uids = searchResults.slice(-5);
                    
                    for (const uid of uids) {
                        const message = await client.fetchOne(uid, {
                            source: true,
                            envelope: true,
                            bodyStructure: true
                        });
                        
                        messages.push(message);
                    }
                } catch (err) {
                    console.log(`No emails from ${sender}`);
                }
            }
            
            // Sort by date (newest first)
            messages.sort((a, b) => b.envelope.date - a.envelope.date);
            
            // Extract OTP from messages
            for (const message of messages) {
                const subject = message.envelope.subject || '';
                const bodyText = message.source.toString();
                
                const otp = extractOTP(bodyText);
                
                if (otp) {
                    return {
                        success: true,
                        otp: otp,
                        from: message.envelope.from[0].address,
                        subject: subject,
                        receivedAt: message.envelope.date
                    };
                }
            }
            
            return {
                success: false,
                error: `No verification code found from ${platform}`
            };
            
        } finally {
            lock.release();
        }
        
    } catch (error) {
        console.error('[IMAP ERROR]', error.message);
        
        if (error.message.includes('authentication') || error.message.includes('Invalid credentials')) {
            return {
                success: false,
                error: 'Invalid email or password'
            };
        }
        
        return {
            success: false,
            error: error.message
        };
    } finally {
        await client.logout();
    }
}

// Main API endpoint
app.post('/api/extract-otp', async (req, res) => {
    try {
        const { email, password, token, uuid, platform } = req.body;

        if (!email || !password) {
            return res.json({ 
                success: false, 
                error: 'Email and password are required' 
            });
        }

        console.log(`[${new Date().toISOString()}] Processing request for ${email} (${platform})`);

        const result = await fetchEmailsViaIMAP(email, password, platform);
        
        res.json(result);

    } catch (error) {
        console.error('[ERROR]', error.message);
        res.json({ 
            success: false, 
            error: error.message || 'Failed to fetch emails' 
        });
    }
});

